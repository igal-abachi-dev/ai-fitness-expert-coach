NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# --- Provider API keys -------------------------------------------------------
# Set only the key(s) for the providers your model roles reference below.
# The free-tier default stack needs GOOGLE + CEREBRAS (no credit card):
#   Google:   https://aistudio.google.com  -> "Get API key"
#             Use a FRESH project and NEVER enable billing on it, or the free
#             tier is removed and every call becomes billable.
#   Cerebras: https://cloud.cerebras.ai     -> sign up by email -> API keys
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Optional extra free / paid providers:
# GROQ_API_KEY=your_groq_api_key_here        # https://console.groq.com (free)
# XAI_API_KEY=your_grok_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=sk-ant-...

# --- Model roles -------------------------------------------------------------
# Each is a "<provider>/<modelId>" spec. Switching provider/model is an env
# change, never a code change. A role falls back to AGENT_MODEL when unset.
#   quality -> /plan primary (best free structured output)
#   cheap   -> /ask + /plan quota-overflow fallback (high volume)
#   fast    -> /chat stream (lowest latency)
QUALITY_MODEL=google/gemini-3-flash-preview
CHEAP_MODEL=google/gemini-3.1-flash-lite
FAST_MODEL=cerebras/gpt-oss-120b

# Legacy single-model knob + per-role fallback.
AGENT_MODEL=google/gemini-3-flash-preview

# Concrete frontend origin (e.g. http://localhost:5173 for Vite dev).
# A literal "*" is rejected at startup when NODE_ENV=production.
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_MAX=30
